#!/usr/bin/env perl

use strict;
use warnings;
use FindBin qw($Bin);
use lib ( -d "$Bin/../lib/perl5" ? "$Bin/../lib/perl5" : "$Bin/../lib" );
use Getopt::Long;
use Pod::Usage;
use WTSI::DNAP::Warehouse::Schema;

our $VERSION = '0';

my $id_run = 0;
my $help   = q[];
my $drop_irods_locations = 0;

GetOptions ('help'     => \$help,
            'id_run=i' => \$id_run,
            'drop_irods_locations' => \$drop_irods_locations,);

my $sections = 'NAME|DESCRIPTION|USAGE|REQUIRED ARGUMENTS|OPTIONS';

if($help) {
  pod2usage(-exitval => 1, -verbose => 99, -sections => $sections);
}

if (!$id_run) {
  warn "\nERROR: 'id_run' is required\n\n";
  pod2usage(-exitval => 1, -verbose => 99, -sections => $sections);
}

my $illumina_platform = 'Illumina';
my @platforms = (
  ['IseqRunLaneMetric', 'IseqProductMetric', $illumina_platform],
  [qw/EseqRunLaneMetric EseqProductMetric Elembio/],
  [qw/UseqRunMetric UseqProductMetric Ultimagen/],
);

my $schema_wh = WTSI::DNAP::Warehouse::Schema->connect();
my $where = {id_run => $id_run};

for my $names (@platforms) {

  my $transaction = sub {
    my $rs_name = $names->[0];
    my $platform = $names->[2];
    my $rs = $schema_wh->resultset($rs_name)->search($where);
    if ($rs->count() == 0) {
      warn "No record for run $id_run in $platform platform tables\n";
      return 0;
    } else {
      warn sprintf "This is $platform platform run $id_run\n";
    }

    $rs_name = $names->[1];
    my $rs_product = $schema_wh->resultset($rs_name)->search($where);
    for my $product_row ($rs_product->all()) {
      if ($platform eq $illumina_platform) {
        $product_row->iseq_product_ampliconstats()->delete();
        $product_row->iseq_product_components()->delete();
      }
      if ($drop_irods_locations) {
        $product_row->seq_product_irods_locations()->delete();
      }
    }

    $rs_product->delete();
    $rs->delete();

    return 1;
  };

  if ($schema_wh->txn_do($transaction)) {
    warn "Run $id_run deleted from ml warehouse\n";
    last; # Do not try tables for the next sequencing platform.
  }
}

exit 0;

__END__

=head1 NAME

npg_mlwarehouse_run_delete

=head1 SYNOPSIS

  npg_mlwarehouse_run_delete [options]

=head1 DESCRIPTION

Script for deleting sequencing run metrics data from
L<multi-lims warehouse|https://github.com/wtsi-npg/ml_warehouse>.

Examines C<iseq_run_lane_metrics>, C<eseq_run_lane_metrics> and C<useq_run_metrics>
tables establishing the sequencing platform this run belongs to. If rows for
the given C<id_run> are found in any of these tables, the search stops and
records are deleted for this run from all relevant platform-specific tables.

For Illumina platform the script deletes rows from C<iseq_run_lane_metrics>,
C<iseq_product_metrics>, C<iseq_product_component> and C<iseq_product_ampliconstats>
tables.

For Elembio platform the script deletes rows from C<eseq_run_lane_metrics> and
C<eseq_product_metrics> tables.

For Ultimagen platform the script deletes rows from C<useq_run_metrics> and
C<useq_product_metrics> tables.

If C<--drop_irods_locations> option is enabled, platform relevant records are
deleted from C<seq_product_irods_locations>.

Deletion is performed as a single transaction. If an error
occurs during the transaction, nothing is deleted.

If a product row of this run is a component of some other
product that does not belong to this run, this row and the
run itself cannot be deleted.

=head1 DESCRIPTION

=head1 USAGE

  npg_mlwarehouse_run_delete --id_run 45

  npg_mlwarehouse_run_delete --id_run 45 --drop_irods_locations

=head1 REQUIRED ARGUMENTS

id_run

=head1 OPTIONS

  --help                  brief help message
  --id_run                ID of the run to delete
  --drop_irods_locations  a boolean option, if true, records in the
    seq_product_irods_locations table are dropped, false by default

=head1 EXIT STATUS

0

=head1 CONFIGURATION

=head1 DIAGNOSTICS

=head1 DEPENDENCIES

=over

=item strict

=item warnings

=item lib

=item FindBin

=item Getopt::Long

=item Pod::Usage

=item WTSI::DNAP::Warehouse::Schema

=back

